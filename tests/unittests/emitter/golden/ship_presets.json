{
  "version": 6,
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "debug",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKELESS_SANITIZE": "address"
      }
    },
    {
      "name": "release",
      "displayName": "release",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_INTERPROCEDURAL_OPTIMIZATION": "ON"
      }
    },
    {
      "name": "cross",
      "displayName": "cross",
      "binaryDir": "${sourceDir}/build/cross",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      },
      "toolchainFile": "${sourceDir}/cmake/toolchains/arm64-linux.cmake"
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "cross",
      "configurePreset": "cross"
    }
  ],
  "testPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "release",
      "configurePreset": "release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "cross",
      "configurePreset": "cross",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
